// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
generator client {
  provider = "prisma-client-js"
}


model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  techStack   String
  githubUrl   String
  liveUrl     String?
  createdAt   DateTime @default(now())
}
model ResumeDownload {
  id        Int      @id @default(autoincrement())
  email     String
  company   String?  // The '?' means it can be null/unknown
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}